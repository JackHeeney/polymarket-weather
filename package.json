{
  "name": "polymarket-weather",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "core/*"
  ],
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "build": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema packages/db/prisma/schema.prisma",
    "db:seed": "tsx packages/db/prisma/seed.ts",
    "api:start": "tsx apps/api/src/server.ts",
    "dashboard:start": "tsx apps/web-dashboard/src/server.ts",
    "engine:run": "tsx core/engine/src/runPipeline.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "express": "^5.1.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.1",
    "eslint": "^10.2.0",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^2.1.8"
  }
}
